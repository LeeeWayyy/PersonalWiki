---
import Base from '../layouts/Base.astro';
---
<Base title="Search" crumbs={[{ label: 'Search' }]}>
  <div class="title-row"><h1>Search</h1><div class="metaline">Full-text search across the vault (Pagefind)</div></div>
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <div id="search"></div>
  <p class="muted small" id="pf-note" style="margin-top:16px">
    Search index is generated at build time (<code>npm run build</code>). In dev, run a production build + <code>npm run preview</code>.
  </p>
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (typeof PagefindUI === 'undefined') return;
      document.getElementById('pf-note')?.remove();
      new PagefindUI({ element: '#search', showSubResults: true, showImages: false });
    });
  </script>
</Base>
