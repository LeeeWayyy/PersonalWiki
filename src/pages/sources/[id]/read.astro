---
import Base from '../../../layouts/Base.astro';
import SourceReader from '../../../components/SourceReader.astro';
import { loadVault, blocksForSource, citationsForSource, cleanTitle as clean } from '../../../lib/vault.mjs';
import { sourceReaderChapterHref, sourceReaderSections } from '../../../lib/source-reader-chapters.mjs';
import { t } from '../../../lib/i18n.mjs';
import type { SourceMeta, Citation } from '../../../lib/vault.mjs';

export async function getStaticPaths() {
  const { sources } = loadVault();
  return sources.map((s: SourceMeta) => {
    const fullDoc = blocksForSource(s.id);
    const chapters = sourceReaderSections(fullDoc?.blocks || []);
    const redirectHref = chapters.length > 1 ? sourceReaderChapterHref(s.id, chapters[0]) : '';
    return {
      params: { id: s.id },
      props: {
        source: s,
        doc: redirectHref ? null : fullDoc,
        citations: redirectHref ? [] : citationsForSource(s.id),
        chapters,
        redirectHref,
      },
    };
  });
}
const { source, doc, citations, chapters: sourceChapters, redirectHref } = Astro.props as {
  source: SourceMeta;
  doc: any;
  citations: Citation[];
  chapters: any[];
  redirectHref: string;
};
const isChapterRedirect = !!redirectHref;
const blocks = doc?.blocks ?? [];
const chapters = sourceChapters?.length ? sourceChapters : sourceReaderSections(blocks);
const chapterLinks = chapters.map((chapter) => ({
  ...chapter,
  href: sourceReaderChapterHref(source.id, chapter),
}));
const displayBlockCount = isChapterRedirect
  ? chapters.reduce((sum, chapter) => sum + (chapter.block_count || 0), 0)
  : blocks.length;
const redirectTargets = chapterLinks.map((chapter) => ({
  href: chapter.href,
  title: chapter.title,
  section: chapter.section,
  section_id: chapter.section_id,
  blocks: chapter.blocks.map((block: any) => ({ id: block.id })),
}));
const readerProps = {
  source, blocks, citations, promoteFrom: citations, chapterLinks,
  hasToc: chapterLinks.length > 1,
  detailKey: 'sr.detail',
  detailArgs: { type: source.origin_type, n: chapterLinks.length, b: displayBlockCount },
  configExtras: { chapterScoped: false },
};
---
<Base title={clean(source.title)} active="sources" crumbs={[{ i18n: 'kind.sources', href: '/sources' }, { label: clean(source.title), href: `/sources/${source.id}` }, { i18n: 'crumb.read' }]}>
  {isChapterRedirect ? (
    <SourceReader {...readerProps}>
      <div id="sr-read-redirect" class="card" data-href={redirectHref} data-chapters={JSON.stringify(redirectTargets)}>
        <p class="muted" data-i18n="sr.split">{t('sr.split')}</p>
        <p><a href={redirectHref} data-i18n="sr.openFirst">{t('sr.openFirst')}</a></p>
      </div>
      <script>
        import { bootSourceReaderRedirect } from '../../../scripts/source-reader-redirect.js';
        bootSourceReaderRedirect();
      </script>
    </SourceReader>
  ) : (
    <SourceReader {...readerProps} />
  )}
</Base>
