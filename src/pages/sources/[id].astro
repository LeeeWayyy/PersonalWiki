---
import Base from '../../layouts/Base.astro';
import { loadVault, sourceHasBlocks, sourceReaderHref } from '../../lib/vault.mjs';
import { t } from '../../lib/i18n.mjs';
import type { SourceMeta } from '../../lib/vault.mjs';

export async function getStaticPaths() {
  const { sources } = loadVault();
  return sources.map((s: SourceMeta) => ({ params: { id: s.id }, props: { source: s } }));
}
const { source } = Astro.props as { source: SourceMeta };
const { pages } = loadVault();
const readable = sourceHasBlocks(source.id);
const readHref = sourceReaderHref(source.id);
const citedBy = pages.filter((p) => (p.sources || []).includes(source.id))
  .sort((a, b) => a.title.localeCompare(b.title, 'zh'));
---
<Base title={source.title} active="sources" crumbs={[{ i18n: 'kind.sources', href: '/sources' }, { label: source.title }]} rail={true}>
  {readable && <a slot="topright" class="btn-accent" style="padding:6px 14px;text-decoration:none" href={readHref} data-i18n="act.read">{t('act.read')}</a>}
  <article class="prose">
    <div class="title-row">
      <h1>{source.title}</h1>
      <div class="metaline"><span data-i18n="kind.source">{t('kind.source')}</span> · {source.origin_type} · <code>{source.id}</code></div>
    </div>
    <div class="card">
      <h3 data-i18n="prov.title">{t('prov.title')}</h3>
      <p class="small" data-i18n="prov.body" data-i18n-args={JSON.stringify({ id: source.id })}>{t('prov.body', { id: source.id })}</p>
      {source.origin_ref ? <p class="small muted" data-i18n="prov.origin" data-i18n-args={JSON.stringify({ ref: source.origin_ref })}>{t('prov.origin', { ref: source.origin_ref })}</p> : null}
      {source.supersedes ? <p class="small muted" data-i18n="prov.supersedes" data-i18n-args={JSON.stringify({ id: source.supersedes })}>{t('prov.supersedes', { id: source.supersedes })}</p> : null}
    </div>
    <h2 data-i18n="srcd.citedBy" data-i18n-args={JSON.stringify({ n: citedBy.length })}>{t('srcd.citedBy', { n: citedBy.length })}</h2>
    <ul class="pagelist">
      {citedBy.map((p) => <li><a href={p.href}>{p.title} <span class="muted small">· {p.kind === 'entity' || p.kind === 'topic' ? <span data-i18n={`kind.${p.kind}`}>{t(`kind.${p.kind}`)}</span> : p.kind}</span></a></li>)}
    </ul>
  </article>
  <Fragment slot="rail">
    <div class="rail-block"><h4 data-i18n="rail.type">{t('rail.type')}</h4><span class="chip">{source.origin_type}</span></div>
  </Fragment>
</Base>
