---
import Base from '../../layouts/Base.astro';
import { loadLang, readingStats } from '../../lib/vault.mjs';
import { t } from '../../lib/i18n.mjs';
import type { LangEntry } from '../../lib/vault.mjs';

export async function getStaticPaths() {
  return loadLang().map((l: LangEntry) => ({ params: { slug: l.slug }, props: { lang: l } }));
}
const { lang } = Astro.props as { lang: LangEntry };
const reading = lang.reading;
const stats = readingStats(reading);
const metrics = [
  { k: 'reader.immersion', n: null },
  Number.isFinite(stats.word_count) ? { k: 'n.words', n: stats.word_count } : null,
  Number.isFinite(stats.grammar_count) ? { k: 'n.grammar', n: stats.grammar_count } : null,
].filter(Boolean) as Array<{ k: string; n: number | null }>;
const readingPayload = reading ? JSON.stringify({ reading, sourceId: lang.id }).replace(/</g, '\\u003c') : '';
---
<Base title={lang.title} active="reader" crumbs={[{ i18n: 'crumb.reader', href: '/reader' }, { label: lang.title }]}>
  <style is:global>
    #rd .jp { font-family: var(--jp); line-height: 2.05; color: #ece2d1; }
    #rd ruby rt { font-size: .5em; color: var(--text-3); font-family: var(--sans); font-weight: 400; transition: opacity .15s; }
    #rd.furi-off ruby rt { opacity: 0; }
    #rd .en { font-size: 14.5px; color: var(--text-2); line-height: 1.6; margin-top: 7px; font-family: var(--sans); }
    #rd.trans-hide .en { display: none; }
    #rd.trans-tap .en { display: none; }
    #rd.trans-tap .sent.reveal .en { display: block; }
    #rd .sent { padding: 9px 12px; margin: 2px -12px; border-radius: 10px; }
    #rd .sent:hover { background: var(--bg-1); }
    #rd .word:hover { filter: brightness(1.35); }
    #rd-toolbar button { font-family: var(--sans); }
    /* ponytail: native offscreen virtualization — browser skips layout/paint for paragraphs out of view */
    #rd .para { content-visibility: auto; contain-intrinsic-size: auto 220px; }
    #rd-pager button { background: var(--bg-2); color: var(--text); border: 1px solid var(--border-strong); border-radius: 8px; padding: 7px 14px; font-size: 13px; cursor: pointer; }
    #rd-pager button:disabled { opacity: .35; cursor: default; }
    #rd-chap { background: var(--bg-2); color: var(--text); border: 1px solid var(--border); border-radius: 8px; padding: 7px 10px; font-size: 13px; font-family: var(--sans); max-width: min(60vw, 420px); }
  </style>

  <div style="max-width:1180px;margin:0 auto">
    <div style="margin-bottom:22px">
      <div style="display:flex;align-items:center;gap:9px;margin-bottom:10px">
        <span style="font-size:10.5px;font-family:var(--mono);letter-spacing:.06em;text-transform:uppercase;color:var(--amber);border:1px solid color-mix(in srgb,var(--amber) 42%,transparent);border-radius:5px;padding:2px 7px">JA · 日本語</span>
        <span style="font-size:12px;color:var(--text-3);font-family:var(--mono)">{metrics.map((m, i) => (<>{i ? ' · ' : ''}<span data-i18n={m.k} data-i18n-args={m.n == null ? undefined : JSON.stringify({ n: m.n })}>{m.n == null ? t(m.k) : t(m.k, { n: m.n })}</span></>))}</span>
      </div>
      <h1 style="font-family:var(--jp);font-size:32px;font-weight:600;line-height:1.2;margin:0">{lang.title}</h1>
    </div>

    {reading ? (
      <>
        <div id="rd-toolbar" style="position:sticky;top:52px;z-index:4;display:flex;gap:10px;align-items:center;flex-wrap:wrap;background:var(--bg-1);border:1px solid var(--border);border-radius:12px;padding:9px 12px;margin-bottom:26px;box-shadow:0 8px 24px -14px rgba(0,0,0,.6)">
          <button id="t-furi">ふりがな</button>
          <div style="display:flex;align-items:center;gap:7px">
            <span style="font-size:12px;color:var(--text-3)">訳</span>
            <div class="seg" id="t-trans" style="padding:2px">
              <button data-m="show" class="on" style="flex:none">表示</button>
              <button data-m="tap" style="flex:none">タップ</button>
              <button data-m="hide" style="flex:none">非表示</button>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:7px">
            <span style="font-size:12px;color:var(--text-3)">表示</span>
            <div class="seg" id="t-view" style="padding:2px">
              <button data-v="scroll" class="on" style="flex:none">スクロール</button>
              <button data-v="page" style="flex:none">ページ</button>
            </div>
          </div>
          <div class="seg" style="padding:2px">
            <button id="t-smaller" style="flex:none;font-family:var(--serif);font-size:13px">A−</button>
            <button id="t-bigger" style="flex:none;font-family:var(--serif);font-size:17px">A+</button>
          </div>
          <div style="margin-left:auto;display:flex;align-items:center;gap:9px">
            <span style="font-size:12px;font-family:var(--mono);color:var(--amber)"><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:color-mix(in srgb,var(--amber) 60%,transparent);border:1px solid var(--amber);margin-right:5px;vertical-align:middle"></span><span id="c-new">0</span> <span data-i18n="reader.new">{t('reader.new')}</span></span>
            <span style="font-size:12px;font-family:var(--mono);color:var(--sage)">★ <span id="c-saved">0</span> <span data-i18n="reader.saved">{t('reader.saved')}</span></span>
          </div>
        </div>

        <div id="pos-legend" style="display:flex;flex-wrap:wrap;gap:7px;margin-bottom:22px;align-items:center">
          <span style="font-size:11px;color:var(--text-3);font-family:var(--mono);text-transform:uppercase;letter-spacing:.06em;margin-right:3px">品詞 · pos</span>
        </div>

        <div class="rd-layout">
          <div id="rd"></div>
          <aside class="rd-rail" id="rd-rail">
            <div class="rd-tabs">
              <button type="button" data-tab="word" class="on">単語 <span style="opacity:.65">Word</span></button>
              <button type="button" data-tab="grammar">文法 <span style="opacity:.65">Grammar</span></button>
            </div>
            <div id="rd-rail-body"></div>
          </aside>
        </div>
        <div id="rd-pager" style="display:none;align-items:center;justify-content:center;gap:14px;margin:28px 0 6px;font-family:var(--sans)">
          <button id="rd-prev" type="button">← 前</button>
          <select id="rd-chap" aria-label="chapter"></select>
          <button id="rd-next" type="button">次 →</button>
        </div>
        <div id="rd-sheet" style="position:fixed;left:0;right:0;bottom:0;z-index:30;background:var(--bg-2);border-top:1px solid var(--border-strong);box-shadow:0 -10px 34px rgba(0,0,0,.5);padding:18px 24px 26px;font-family:var(--sans);max-height:52vh;overflow:auto;transition:transform .22s ease;transform:translateY(115%)">
          <div style="max-width:640px;margin:0 auto;position:relative">
            <button id="sheet-x" style="position:absolute;right:0;top:-2px;background:none;border:none;color:var(--text-3);font-size:22px;cursor:pointer;line-height:1">×</button>
            <div id="sheet-body"></div>
          </div>
        </div>

        <script is:inline id="reading-data" type="application/json" set:html={readingPayload}></script>
        <script is:inline>
          const { reading, sourceId } = JSON.parse(document.getElementById('reading-data').textContent);
          // ponytail: is:inline script can't import lib/i18n.mjs — the JP immersion labels
          // (ふりがな/表示/文法…) are part of the reader's design; only these few
          // status messages are language-switched, via a local EN flag.
          const EN = (localStorage.getItem('pw:lang') || 'zh') === 'en';
          const BACKEND = localStorage.getItem('backendUrl') || 'http://localhost:8787';
          const TOKEN = localStorage.getItem('backendToken') || '';
          const H = TOKEN ? { 'X-Auth-Token': TOKEN } : {};
          const saved = new Set();
          let fontSize = 24, furi = true, trans = 'show';
          const POSKEY = 'pw:read:' + sourceId;
          let pageMode = false, curPage = 0, savedY = 0;
          try { const p = JSON.parse(localStorage.getItem(POSKEY) || '{}'); pageMode = !!p.mode; curPage = p.page || 0; savedY = p.y || 0; } catch {}
          const parasOf = (ch) => ch.paragraphs || [{ sentences: ch.sentences || [] }];
          const tokensOf = (s) => Array.isArray(s.tokens) && s.tokens.length
            ? s.tokens
            : [{ t: s.jp || s.text || '' }];

          const POS = { '動詞': 'var(--terra)', '形容詞': 'var(--amber)', '形容動詞': '#cbb96a', '形状詞': '#cbb96a',
            '名詞': 'var(--sage)', '代名詞': '#c790a6', '副詞': '#6fa6b2', '連体詞': '#9a94c4' };
          function posStyle(pos, isNew) {
            const hue = POS[pos] || null;
            let s = 'cursor:pointer;border-radius:3px;padding:0 1px;transition:filter .12s;';
            if (hue) s += `background:color-mix(in srgb,${hue} 17%,var(--bg-2));`;
            s += isNew ? 'border-bottom:2px solid var(--amber);'
              : hue ? `border-bottom:1px solid color-mix(in srgb,${hue} 45%,transparent);`
                    : 'border-bottom:1px dotted var(--border-strong);';
            return s;
          }
          function esc(s){return (s+'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
          function att(s){return esc(s).replace(/"/g,'&quot;');}

          // POS legend
          const legend = document.getElementById('pos-legend');
          [['動詞','verb','var(--terra)'],['形容詞','i-adj','var(--amber)'],['形容動詞','na-adj','#cbb96a'],
           ['名詞','noun','var(--sage)'],['副詞','adverb','#6fa6b2'],['代名詞','pronoun','#c790a6']].forEach(([jp,en,hue]) => {
            const el = document.createElement('span');
            el.style.cssText = `display:inline-flex;align-items:center;gap:6px;padding:2px 10px;border-radius:20px;font-size:12px;background:color-mix(in srgb,${hue} 17%,var(--bg-2));border:1px solid color-mix(in srgb,${hue} 40%,var(--border))`;
            el.innerHTML = `<span style="font-family:var(--jp);color:var(--text)">${jp}</span><span style="color:var(--text-3);font-size:11px">${en}</span>`;
            legend.appendChild(el);
          });

          const rd = document.getElementById('rd');
          const sheet = document.getElementById('rd-sheet');
          const sheetBody = document.getElementById('sheet-body');

          async function loadKnown() {
            try { const r = await fetch(`${BACKEND}/vocab?kind=word`, { headers: H }); if (r.ok) (await r.json()).forEach((i) => saved.add(i.lemma)); } catch {}
            document.getElementById('c-saved').textContent = saved.size;
          }

          // Grammar card bank (lemma → item), lazy-loaded on first 文法 chip tap.
          let gbank = null;
          async function grammarBank() {
            if (!gbank) {
              try { const r = await fetch(`${BACKEND}/vocab?kind=grammar`, { headers: H }); if (r.ok) gbank = new Map((await r.json()).map((i) => [i.lemma, i])); } catch {}
              gbank = gbank || new Map();
            }
            return gbank;
          }

          function tokenHtml(t) {
            const ruby = t.rt ? `<ruby>${esc(t.t)}<rt>${esc(t.rt)}</rt></ruby>` : esc(t.t);
            if (!t.w || !t.m) return ruby;
            const isNew = t.new && !saved.has(t.w);
            return `<span class="word" data-w="${att(t.w)}" data-r="${att(t.rt || t.t)}" data-m="${att(t.m)}" data-n="${att(t.n || '')}" data-p="${att(t.pos || '')}" style="${posStyle(t.pos, isNew)}">${ruby}</span>`;
          }

          function countNew() {
            let n = 0;
            for (const ch of reading.chapters) for (const para of parasOf(ch)) for (const s of para.sentences)
              for (const tk of tokensOf(s)) if (tk.w && tk.m && tk.new && !saved.has(tk.w)) n++;
            return n;
          }
          function updateNewCount() { document.getElementById('c-new').textContent = countNew(); }

          function render() {
            rd.innerHTML = '';
            if (pageMode) curPage = Math.max(0, Math.min(curPage, reading.chapters.length - 1));
            // ponytail: page mode renders one chapter's DOM at a time; scroll mode renders all
            const chapters = pageMode ? (reading.chapters[curPage] ? [reading.chapters[curPage]] : []) : reading.chapters;
            for (const ch of chapters) {
              if (ch.chapter) { const h = document.createElement('div'); h.style.cssText = 'font-family:var(--jp);font-size:19px;font-weight:600;color:var(--text);border-bottom:1px solid var(--border);padding-bottom:8px;margin:26px 0 18px'; h.textContent = ch.chapter; rd.appendChild(h); }
              for (const para of parasOf(ch)) {
                const pEl = document.createElement('div'); pEl.className = 'para'; pEl.style.cssText = 'margin:0 0 20px;border-left:2px solid transparent;padding-left:4px';
                for (const s of para.sentences) {
                  const tokens = tokensOf(s);
                  const el = document.createElement('div'); el.className = 'sent';
                  const jp = document.createElement('div'); jp.className = 'jp'; jp.style.fontSize = fontSize + 'px';
                  jp.innerHTML = tokens.map(tokenHtml).join('');
                  el.appendChild(jp);
                  if (s.grammar && s.grammar.length) {
                    // Superscript 文N chip at the end of the sentence line; opens the
                    // study rail's Grammar tab (bottom sheet on ≤760px). No inline shove.
                    const chip = document.createElement('span');
                    chip.className = 'rd-gchip';
                    chip.textContent = '文' + s.grammar.length;
                    chip.onclick = (e) => { e.stopPropagation(); showGrammar(s.grammar, chip); };
                    jp.appendChild(chip);
                  }
                  const en = document.createElement('div'); en.className = 'en'; en.textContent = s.en || ''; en.dataset.jp = s.jp || s.text || tokens.map((t) => t.t || '').join('');
                  el.appendChild(en);
                  el.addEventListener('click', () => onSentence(el, en));
                  pEl.appendChild(el);
                }
                rd.appendChild(pEl);
              }
            }
            updateNewCount();
            applyModes();
            updatePager();
          }

          function updatePager() {
            const bar = document.getElementById('rd-pager');
            bar.style.display = pageMode ? 'flex' : 'none';
            if (!pageMode) return;
            document.getElementById('rd-chap').value = String(curPage);
            document.getElementById('rd-prev').disabled = curPage === 0;
            document.getElementById('rd-next').disabled = curPage === reading.chapters.length - 1;
          }

          function applyModes() {
            rd.className = (furi ? '' : 'furi-off') + (trans === 'hide' ? ' trans-hide' : '') + (trans === 'tap' ? ' trans-tap' : '');
          }

          async function onSentence(el, en) {
            if (trans === 'tap') el.classList.toggle('reveal');
            if (!en.textContent) {
              en.textContent = '…';
              try { const r = await fetch(`${BACKEND}/translate`, { method: 'POST', headers: { 'Content-Type': 'application/json', ...H }, body: JSON.stringify({ text: en.dataset.jp, lang: 'ja' }) });
                en.textContent = r.ok ? (await r.json()).translation : (EN ? '(translation unavailable)' : '（翻译不可用）'); }
              catch { en.textContent = EN
                ? `(study backend offline — start it: cd backend && bash run.sh · expected at ${BACKEND})`
                : `（学习后端未运行 — 启动方式：cd backend && bash run.sh · 预期地址 ${BACKEND}）`; }
            }
          }

          // ---- Study rail (word + grammar); bottom-sheet fallback on ≤760px ----
          const railBody = document.getElementById('rd-rail-body');
          const isMobile = () => window.matchMedia('(max-width: 760px)').matches;
          let tab = 'word', curWord = null, curGrammar = null;
          const posColor = (p) => POS[p] || 'var(--text-3)';

          function wordCardHtml(d) {
            const already = saved.has(d.w);
            const col = posColor(d.p);
            return `<div class="rd-wcard">
              <div class="rd-wtop"><div class="rd-whead">${esc(d.w)}</div>${d.p ? `<span class="rd-wpos" style="color:${col};border-color:color-mix(in srgb,${col} 45%,var(--border))">${esc(d.p)}</span>` : ''}</div>
              <div class="rd-wread">${esc(d.r)}</div>
              <div class="rd-wgloss">${esc(d.m)}</div>
              ${d.n ? `<div class="rd-wex">${esc(d.n)}</div>` : ''}
              <div class="rd-wacts"><button id="sv" class="rd-wsave">${already ? '★ 保存済み' : '★ 保存'}</button><button id="sv-known" class="rd-wknown">既知</button></div>
            </div>`;
          }
          const wordEmptyHtml = () => `<div class="rd-empty"><div class="rd-empty-ico">✎</div><div class="rd-empty-jp">文中の単語をタップすると<br>ここに意味が表示されます</div><div class="rd-empty-en">Tap any word to see it here</div></div>`;
          const grammarEmptyHtml = () => `<div class="rd-empty"><div class="rd-empty-jp">「文法」チップをタップ</div><div class="rd-empty-en">Tap a 文法 chip on a sentence</div></div>`;

          function grammarCardHtml(g, bank) {
            const bk = g.card && bank.get(g.card);
            const card = bk ? `<div style="margin:9px 0 0;padding:8px 11px;border-left:2px solid var(--terra);background:var(--bg-2);border-radius:0 8px 8px 0"><div style="font-size:12px"><span style="font-family:var(--jp);font-weight:600;color:var(--text)">📖 ${esc(bk.lemma)}</span>${bk.pos ? `<span style="color:var(--text-3)"> · ${esc(bk.pos)}</span>` : ''}<button class="gadd" data-lemma="${att(bk.lemma)}" ${bk.status !== 'known' ? 'disabled' : ''} style="float:right;background:var(--bg-3);color:var(--text);border:1px solid var(--border-strong);border-radius:7px;padding:2px 9px;font-size:11px;cursor:pointer;font-family:var(--sans)">${bk.status !== 'known' ? (EN ? 'in review' : '复习中') : (EN ? '+ review' : '＋复习')}</button></div><div style="white-space:pre-line;font-size:12.5px;color:var(--text-2);margin-top:4px">${esc(bk.gloss || '')}</div>${bk.example ? `<div style="white-space:pre-line;font-family:var(--jp);font-size:12px;color:var(--text-3);margin-top:5px">${esc(bk.example)}</div>` : ''}</div>` : '';
            const expl = (!EN && g.explanation_tr) || g.explanation;
            return `<div class="rd-gcard"><div class="rd-gpat">${esc(g.pattern)}</div><div class="rd-gexpl">${esc(expl)}</div>${g.example_jp ? `<div class="rd-gex">${esc(g.example_jp)}</div>` : ''}${card}</div>`;
          }

          function wireWordButtons(d) {
            const sv = document.getElementById('sv'), svk = document.getElementById('sv-known');
            if (sv) sv.onclick = () => saveWord(d, null);
            if (svk) svk.onclick = () => saveWord(d, 'known');
          }
          function wireGadd(bank, root) {
            root.querySelectorAll('.gadd').forEach((b) => b.onclick = async (ev) => { ev.stopPropagation();
              const it = bank.get(b.dataset.lemma); if (!it) return;
              try {
                const r = await fetch(`${BACKEND}/vocab/${it.id}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json', ...H }, body: JSON.stringify({ status: 'new' }) });
                if (!r.ok) throw new Error();
                it.status = 'new'; b.textContent = EN ? 'in review' : '复习中'; b.disabled = true;
              } catch { alert(EN ? 'Could not reach study backend (' + BACKEND + ').' : '无法连接学习后端（' + BACKEND + '）。'); }
            });
          }
          function setTab(next) { tab = next; document.querySelectorAll('.rd-tabs button').forEach((b) => b.classList.toggle('on', b.dataset.tab === tab)); }

          function showWord(d) {
            curWord = d;
            if (isMobile()) { sheetBody.innerHTML = wordCardHtml(d); sheet.style.transform = 'none'; }
            else { setTab('word'); railBody.innerHTML = wordCardHtml(d); }
            wireWordButtons(d);
          }

          async function showGrammar(grammar, chip) {
            curGrammar = grammar;
            document.querySelectorAll('.rd-gchip.active').forEach((c) => c.classList.remove('active'));
            chip?.classList.add('active');
            const mobile = isMobile();
            const container = mobile ? sheetBody : railBody;
            if (!mobile) setTab('grammar');
            container.innerHTML = `<div class="rd-empty"><div class="rd-empty-en">…</div></div>`;
            if (mobile) sheet.style.transform = 'none';
            const bank = await grammarBank();
            container.innerHTML = `<div class="rd-glist">${grammar.map((g) => grammarCardHtml(g, bank)).join('')}</div>`;
            wireGadd(bank, container);
          }

          async function saveWord(d, status) {
            try {
              const r = await fetch(`${BACKEND}/vocab`, { method: 'POST', headers: { 'Content-Type': 'application/json', ...H },
                body: JSON.stringify({ kind: 'word', source_id: sourceId, lemma: d.w, reading: d.r, pos: d.p, gloss: d.m }) });
              if (!r.ok) throw new Error();
              const id = (await r.json()).id;
              if (status) await fetch(`${BACKEND}/vocab/${id}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json', ...H }, body: JSON.stringify({ status }) });
              saved.add(d.w); document.getElementById('c-saved').textContent = saved.size;
              // ponytail: restyle just the matching tokens instead of rebuilding the whole document
              rd.querySelectorAll('.word').forEach((w) => { if (w.dataset.w === d.w) w.setAttribute('style', posStyle(w.dataset.p, false)); });
              updateNewCount();
              if (isMobile()) sheet.style.transform = 'translateY(115%)';
              else if (tab === 'word') { railBody.innerHTML = wordCardHtml(d); wireWordButtons(d); }
            } catch { alert(EN ? 'Could not reach study backend (' + BACKEND + ').' : '无法连接学习后端（' + BACKEND + '）。'); }
          }

          // word tap → rail Word card (bottom sheet on mobile)
          rd.addEventListener('click', (e) => {
            const w = e.target.closest('.word'); if (!w) return; e.stopPropagation();
            showWord(w.dataset);
          });
          document.querySelectorAll('.rd-tabs button').forEach((b) => b.onclick = () => {
            setTab(b.dataset.tab);
            if (tab === 'word') { railBody.innerHTML = curWord ? wordCardHtml(curWord) : wordEmptyHtml(); if (curWord) wireWordButtons(curWord); }
            else if (curGrammar) showGrammar(curGrammar); else railBody.innerHTML = grammarEmptyHtml();
          });
          railBody.innerHTML = wordEmptyHtml();
          document.getElementById('sheet-x').onclick = () => { sheet.style.transform = 'translateY(115%)'; };

          // toolbar
          const furiBtn = document.getElementById('t-furi');
          function styleFuri() { furiBtn.style.cssText = (furi ? 'background:var(--terra);color:#1a0f08;font-weight:600;border:1px solid var(--terra);' : 'background:var(--bg-2);color:var(--text-2);border:1px solid var(--border);') + 'border-radius:8px;padding:6px 12px;font-size:12.5px;cursor:pointer'; }
          furiBtn.onclick = () => { furi = !furi; styleFuri(); applyModes(); }; styleFuri();
          document.querySelectorAll('#t-trans button').forEach((b) => b.onclick = () => {
            trans = b.dataset.m; document.querySelectorAll('#t-trans button').forEach((x) => x.classList.toggle('on', x === b)); applyModes();
          });
          document.getElementById('t-bigger').onclick = () => { fontSize = Math.min(34, fontSize + 2); document.querySelectorAll('#rd .jp').forEach((j) => j.style.fontSize = fontSize + 'px'); };
          document.getElementById('t-smaller').onclick = () => { fontSize = Math.max(16, fontSize - 2); document.querySelectorAll('#rd .jp').forEach((j) => j.style.fontSize = fontSize + 'px'); };

          // ---- View mode (scroll ⇄ page) + chapter pager + position memory ----
          const chapSel = document.getElementById('rd-chap');
          chapSel.innerHTML = reading.chapters.map((ch, i) =>
            `<option value="${i}">${esc(ch.chapter || (EN ? 'Chapter ' : '第') + (i + 1) + (EN ? '' : '章'))}</option>`).join('');
          function savePos() { try { localStorage.setItem(POSKEY, JSON.stringify({ mode: pageMode, page: curPage, y: window.scrollY })); } catch {} }
          function goPage(i) { curPage = Math.max(0, Math.min(i, reading.chapters.length - 1)); savePos(); render(); window.scrollTo({ top: 0 }); }
          document.getElementById('rd-prev').onclick = () => goPage(curPage - 1);
          document.getElementById('rd-next').onclick = () => goPage(curPage + 1);
          chapSel.onchange = (e) => goPage(+e.target.value);
          document.querySelectorAll('#t-view button').forEach((b) => {
            b.classList.toggle('on', (b.dataset.v === 'page') === pageMode);
            b.onclick = () => { pageMode = b.dataset.v === 'page';
              document.querySelectorAll('#t-view button').forEach((x) => x.classList.toggle('on', x === b));
              savePos(); render(); window.scrollTo({ top: 0 }); };
          });
          document.addEventListener('keydown', (e) => {
            if (!pageMode || /^(INPUT|SELECT|TEXTAREA)$/.test(e.target.tagName)) return;
            if (e.key === 'ArrowRight') goPage(curPage + 1);
            else if (e.key === 'ArrowLeft') goPage(curPage - 1);
          });
          let scrollT; window.addEventListener('scroll', () => { if (pageMode) return; clearTimeout(scrollT); scrollT = setTimeout(savePos, 300); });

          loadKnown().then(() => { render(); if (!pageMode && savedY) window.scrollTo(0, savedY); });
        </script>
      </>
    ) : (
      <div class="card"><p class="muted" data-i18n="reader.noData">{t('reader.noData')}</p></div>
    )}
  </div>
</Base>
