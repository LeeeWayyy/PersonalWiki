---
import Base from '../../layouts/Base.astro';
import { t } from '../../lib/i18n.mjs';
---
<Base title={t('rv.title')} active="review" crumbs={[{ i18n: 'crumb.reader', href: '/reader' }, { i18n: 'rv.title' }]}>
  <div slot="topright" class="et-seg" id="rv-mode">
    <button data-mode="focus" data-i18n="rv.focus">{t('rv.focus')}</button>
    <button data-mode="info" class="on" data-i18n="rv.info">{t('rv.info')}</button>
  </div>

  <div class="rv-grid" id="rv-grid">
    <!-- left rail: today + this-week forecast -->
    <div class="rv-rail" id="rv-left">
      <div class="rv-panel">
        <h4 data-i18n="rv.today">{t('rv.today')}</h4>
        <div id="rv-today"></div>
        <div class="rv-today-foot"><span class="k" data-i18n="rv.dueTotal">{t('rv.dueTotal')}</span><span class="v" id="rv-duecount">·</span></div>
      </div>
      <div class="rv-panel">
        <h4 data-i18n="rv.week">{t('rv.week')}</h4>
        <div class="rv-fc" id="rv-fc"></div>
        <div class="rv-fc-labels" id="rv-fc-labels"></div>
      </div>
    </div>

    <!-- center: card -->
    <div class="rv-center" id="rv-center">
      <div class="rv-stat-strip" id="rv-strip">
        <div class="rv-kicker" data-i18n="rv.kicker">{t('rv.kicker')}</div>
        <h1 data-i18n="rv.title">{t('rv.title')}</h1>
      </div>
      <div class="rv-progress">
        <div class="track"><span class="fill" id="rv-fill" style="width:0%"></span></div>
        <span class="lb" id="rv-prog" data-i18n="rv.progress" data-i18n-args={JSON.stringify({ a: 0, b: 0 })}>{t('rv.progress', { a: 0, b: 0 })}</span>
      </div>
      <div id="rv-cardwrap" tabindex="0" style="outline:none"><p class="muted" style="text-align:center;padding:40px 0" data-i18n="rv.loading">{t('rv.loading')}</p></div>
    </div>

    <!-- right rail: editable card + FSRS schedule -->
    <div class="rv-rail" id="rv-right">
      <div class="rv-panel rv-edit">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
          <h4 style="margin:0" data-i18n="rv.cardInfo">{t('rv.cardInfo')}</h4>
          <span id="rv-saved" style="font-family:var(--mono);font-size:9.5px;color:var(--sage);opacity:0" data-i18n="rv.autosave">{t('rv.autosave')}</span>
        </div>
        <div id="rv-editfields"></div>
      </div>
    </div>
  </div>

  <script>
    import { t } from '../../lib/i18n.mjs';
    import { api } from '../../scripts/backend-client.js';

    const BACKEND = '';
    const esc = (s: any) => String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    const $ = (id: string) => document.getElementById(id)!;

    let queue: any[] = [], cur: any = null, revealed = false, reviewed = 0;
    let offlineDetail = '', grading = false;
    const wrap = $('rv-cardwrap');

    // grade defs: color + generic FSRS-ish interval hint (real interval comes back from the API)
    const GRADES = [
      { g: 1, label: t('rv.g1'), iv: t('rv.iv1'), col: 'var(--danger)' },
      { g: 2, label: t('rv.g2'), iv: t('rv.iv2'), col: 'var(--amber)' },
      { g: 3, label: t('rv.g3'), iv: t('rv.iv3'), col: 'var(--sage)' },
      { g: 4, label: t('rv.g4'), iv: t('rv.iv4'), col: 'var(--terra)' },
    ];
    const stateLabel = (c: any) => ({ new: t('rv.stNew'), learning: t('rv.stLearning'), known: t('rv.stKnown') } as Record<string, string>)[c.status] || (c.state === 0 ? t('rv.stNew') : t('rv.stReview'));
    function dueLabel(due: string) {
      if (!due) return t('rv.dueToday');
      const d = Math.round((+new Date(due + 'T00:00:00') - +new Date(new Date().toDateString())) / 86400000);
      return d <= 0 ? t('rv.dueToday') : t('rv.dueIn', { n: d });
    }
    function offlineHtml(detail = t('rv.offlineStart'), padding = '12px 0 18px') {
      return `<p class="muted" style="text-align:center;padding:${padding}">${esc(t('rv.offline', { url: BACKEND, detail }))}</p>`;
    }

    function renderProgress() {
      const total = reviewed + queue.length;
      const pct = total ? Math.round((reviewed / total) * 100) : (reviewed ? 100 : 0);
      $('rv-fill').style.width = pct + '%';
      $('rv-prog').textContent = t('rv.progress', { a: reviewed, b: total });
    }

    function renderCard() {
      renderProgress();
      renderEdit();
      cur = queue[0] || null;
      if (!cur) {
        wrap.innerHTML = `<div class="rv-done"><div class="em">🎉</div><div class="h">${esc(t('rv.done'))}</div>
          <div class="sub">${esc(t('rv.doneSub', { n: reviewed }))}</div>
          <button id="rv-restart">${esc(t('rv.again'))}</button></div>`;
        $('rv-restart').onclick = restart;
        return;
      }
      const src = cur.source_id ? `<span class="src">${esc(cur.source_id)}${cur.anchor ? ' · ' + esc(cur.anchor) : ''}</span>` : '';
      const pos = cur.pos || cur.kind || '';
      const answer = revealed ? `<div class="answer">
          <div class="reading">${esc(cur.reading || '')}</div>
          <div class="gloss">${esc(cur.gloss || '')}</div>
          ${cur.example ? `<div class="example">${esc(cur.example)}</div>` : ''}
        </div>` : `<div class="hint">${esc(t('rv.hint'))}</div>`;
      const foot = revealed
        ? `<div class="rv-grades" style="grid-template-columns:repeat(4,1fr)">${GRADES.map((d, i) =>
            `<button data-g="${d.g}" style="background:color-mix(in srgb,${d.col} 15%,var(--bg-2));border:1px solid color-mix(in srgb,${d.col} 40%,var(--border));color:${d.col}">
              <span class="g-l">${d.label}</span><span class="g-i">${d.iv}</span><span class="g-k">${i + 1}</span></button>`).join('')}</div>`
        : `<button class="rv-reveal" id="rv-revealbtn">${esc(t('rv.reveal'))} <span class="k">${esc(t('rv.space'))}</span></button>`;
      wrap.innerHTML = `${offlineDetail ? offlineHtml(offlineDetail) : ''}<div class="rv-card" id="rv-cardface">
          <div class="meta">${pos ? `<span class="pos">${esc(pos)}</span>` : ''}${src}</div>
          <div class="lemma">${esc(cur.lemma || '')}</div>${answer}
        </div>${foot}`;
      $('rv-cardface').onclick = reveal;
      if (!revealed) $('rv-revealbtn').onclick = reveal;
      else wrap.querySelectorAll<HTMLElement>('[data-g]').forEach((b) => (b.onclick = () => grade(+b.dataset.g!)));
    }

    function renderEdit() {
      const box = $('rv-editfields');
      const c = queue[0];
      if (!c) { box.innerHTML = `<p class="muted small">${esc(t('rv.noCard'))}</p>`; return; }
      const f = (label: string, field: string, val: string, style: string, ro?: boolean) =>
        `<label>${esc(label)}</label><input data-field="${field}" value="${esc(val || '')}" style="${style}"${ro ? ' readonly' : ''} />`;
      box.innerHTML =
        f(t('rv.front'), 'lemma', c.lemma, 'font-family:var(--jp);font-size:16px', true) +
        f(t('rv.reading'), 'reading', c.reading, 'font-family:var(--mono);font-size:13px;color:var(--sage)') +
        f(t('rv.gloss'), 'gloss', c.gloss, 'font-family:var(--serifcjk);font-size:14px') +
        `<label>${esc(t('rv.example'))}</label><textarea data-field="example" rows="2" style="font-family:var(--jp);font-size:13px">${esc(c.example || '')}</textarea>` +
        f(t('rv.pos'), 'pos', c.pos, 'font-family:var(--mono);font-size:12px;color:var(--terra)') +
        `<div class="rv-sched"><div class="t">${esc(t('rv.sched'))}</div><div class="rv-sched-grid">
          <div><div class="k">${esc(t('rv.state'))}</div><div class="v" style="font-family:var(--sans);color:var(--text)">${esc(stateLabel(c))}</div></div>
          <div><div class="k">${esc(t('rv.due'))}</div><div class="v" style="color:var(--amber)">${esc(dueLabel(c.due))}</div></div>
          <div><div class="k">${esc(t('rv.stability'))}</div><div class="v">${esc(t('rv.days', { n: (c.stability ?? 0).toFixed(1) }))}</div></div>
          <div><div class="k">${esc(t('rv.difficulty'))}</div><div class="v">${(c.difficulty ?? 0).toFixed(1)}</div></div>
          <div><div class="k">${esc(t('rv.reps'))}</div><div class="v">${c.reps ?? 0}</div></div>
          <div><div class="k">${esc(t('rv.lapses'))}</div><div class="v">${c.lapses ?? 0}</div></div>
        </div></div>`;
    }

    function reveal() { if (!cur || revealed) return; revealed = true; renderCard(); }

    async function grade(g: number) {
      if (!cur || grading) return;
      const card = cur;
      grading = true;
      try {
        const r = await api(`/review/${card.id}/grade`, { method: 'POST', json: { grade: g } });
        if (!r.ok) throw new Error();
      } catch {
        offlineDetail = t('rv.gradeNotSaved');
        grading = false;
        renderCard();
        return;
      }
      queue.shift();
      if (g === 1) queue.push({ ...card }); // grade 1 ("again") re-queues at the end
      reviewed++;
      offlineDetail = '';
      grading = false;
      revealed = false;
      renderCard();
      refreshStats();
    }

    function restart() { revealed = false; reviewed = 0; load(); }

    async function load() {
      try {
        const r = await api('/review/queue');
        if (!r.ok) throw new Error();
        queue = await r.json();
      } catch {
        wrap.innerHTML = offlineHtml(t('rv.offlineStart'), '40px 0');
        return;
      }
      offlineDetail = '';
      revealed = false; renderCard();
    }

    // Left rail — today counts + total-due from /review/stats
    async function fetchStats() {
      try {
        const r = await api('/review/stats'); if (!r.ok) return;
        const s = await r.json();
        const due = Number(s.due ?? 0), nw = Number(s.new ?? 0);
        const rows = [
          { label: t('rv.rowReview'), n: Math.max(0, due - nw), color: 'var(--amber)' },
          { label: t('rv.rowNew'), n: nw, color: 'var(--sage)' },
          { label: t('rv.rowTotal'), n: Number(s.total ?? 0), color: 'var(--terra)' },
        ];
        $('rv-today').innerHTML = rows.map((r2) =>
          `<div class="rv-today-row"><span class="dot" style="background:${r2.color}"></span><span class="lb">${esc(r2.label)}</span><span class="n">${r2.n}</span></div>`).join('');
        $('rv-duecount').textContent = String(due);
      } catch {}
    }

    // This-week forecast — bucket every card's due date from /vocab into today..+6
    async function fetchForecast() {
      let items = [];
      try { const r = await api('/vocab'); if (r.ok) items = await r.json(); } catch { return; }
      const wd = t('rv.wd').split(',');
      const start = new Date(new Date().toDateString());
      const buckets = new Array(7).fill(0);
      for (const it of items as any[]) {
        let d = 0;
        if (it.due) d = Math.round((+new Date(it.due + 'T00:00:00') - +start) / 86400000);
        if (d < 0) d = 0; // overdue → due today
        if (d >= 0 && d < 7) buckets[d]++;
      }
      const max = Math.max(1, ...buckets);
      const bars = buckets.map((n, i) => {
        const dt = new Date(start.getTime() + i * 86400000);
        return { n, h: Math.round((n / max) * 58) + 6, label: i === 0 ? t('rv.todayShort') : wd[dt.getDay()], today: i === 0 };
      });
      $('rv-fc').innerHTML = bars.map((b) =>
        `<div class="rv-fc-col"><span class="n">${b.n}</span><span class="bar" style="height:${b.h}px;background:${b.today ? 'linear-gradient(180deg,var(--terra),var(--amber))' : 'var(--bg-3)'}"></span></div>`).join('');
      $('rv-fc-labels').innerHTML = bars.map((b) =>
        `<span style="color:${b.today ? 'var(--terra)' : 'var(--text-3)'}">${esc(b.label)}</span>`).join('');
    }
    function refreshStats() { fetchStats(); fetchForecast(); }

    // Editable panel — debounced explicit update so cleared fields persist.
    let saveTimer: ReturnType<typeof setTimeout> | null = null;
    function scheduleSave() {
      const c = queue[0]; if (!c) return;
      const saved = $('rv-saved'); saved.style.opacity = '1'; saved.textContent = t('rv.saving');
      if (saveTimer) clearTimeout(saveTimer);
      saveTimer = setTimeout(async () => {
        try {
          const r = await api(`/vocab/${c.id}`, { method: 'PATCH', json: {
            reading: c.reading, gloss: c.gloss, example: c.example, pos: c.pos,
          } });
          if (!r.ok) throw new Error('save failed');
          saved.textContent = t('rv.savedOk');
        } catch { saved.textContent = t('rv.offline2'); }
      }, 600);
    }
    $('rv-editfields').addEventListener('input', (e) => {
      const el = e.target as HTMLInputElement; const field = el.dataset && el.dataset.field; if (!field) return;
      const c = queue[0]; if (!c) return;
      c[field] = el.value;
      if (revealed && field !== 'lemma') renderCard(); // reflect edits on the revealed face
      scheduleSave();
    });

    // Mode toggle (focus / info)
    $('rv-mode').addEventListener('click', (e) => {
      const b = (e.target as Element).closest<HTMLElement>('button[data-mode]'); if (!b) return;
      $('rv-grid').classList.toggle('focus', b.dataset.mode === 'focus');
      $('rv-mode').querySelectorAll('button').forEach((x) => x.classList.toggle('on', x === b));
    });

    // Keyboard: Space/Enter reveal, 1–4 grade
    document.addEventListener('keydown', (e) => {
      const tag = (e.target as HTMLElement).tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA') return;
      if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); reveal(); }
      else if (revealed && /^[1-4]$/.test(e.key)) { e.preventDefault(); grade(+e.key); }
    });

    load(); refreshStats();
  </script>
</Base>
