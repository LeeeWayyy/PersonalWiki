# Copy to backend/.env and adjust. Loaded by app startup and backend serve.
#
# Local wiki folder. Each machine/user can point this at a different folder.
# If unset, the app falls back to this repo's gitignored ./content directory.
# Use an absolute path for launchd and rebuilds.
# PW_CONTENT_DIR=/abs/path/to/wiki-content

# Auth token required on every mutating route (ingest/vocab/grade/translate) and
# on ALL annotation routes. App startup/backend serve generate this automatically
# if it is empty; set it manually only if you need a specific shared token.
PW_AUTH_TOKEN=

# On-demand translation / AI assist and ingest use the shared Python LLM client:
# - PW_LLM_PROVIDER=codex: agentic Codex CLI mode, the subscription-backed
#   default local provider. It invokes `codex exec` directly without a shell
#   bridge and can inspect/edit its isolated workdir.
# - PW_LLM_PROVIDER=api or openai: non-agentic single chat completion against an
#   OpenAI-compatible API. Requires PW_LLM_API_KEY.
# - LLM_CMD: advanced custom stdin->stdout command override.
PW_LLM_PROVIDER=codex
# LLM_CMD=/abs/path/to/custom-stdin-stdout-client
# PW_LLM_HEALTH_TIMEOUT_S=20

# Model for ingest/translate/assist. For codex it is passed as `codex -m`; unset
# uses codex's own default (the latest, priciest model). Ingest rarely needs the
# top model — pin a cheaper one here to cut cost. SEPARATE from CAPTION_MODEL
# below, so text ingest and image captioning run on different models. Can also
# be set per run: `ingest.py --model <name>`.
# PW_LLM_MODEL=gpt-5-codex

# OpenAI-compatible API config. To force non-agentic API mode, set
# PW_LLM_PROVIDER=api (or openai). For legacy fallback behavior, leave
# PW_LLM_PROVIDER=codex and set PW_LLM_API_ENABLED=1; the API is then used only
# when no local provider is configured. An API key exported elsewhere is ignored
# unless one of those explicit API paths is selected.
# PW_LLM_API_ENABLED=0
# PW_LLM_API_KEY=sk-...
# PW_LLM_BASE_URL=https://api.openai.com/v1

# Image captioning (ingest figures → alt text). Backend defaults to the same CLI
# as the LLM (codex) so there's one tool to authenticate; override to run a
# cheaper/different vision CLI. One vision LLM call per non-decorative image, so
# it can be the costliest part of ingesting an image-heavy source.
#   codex  — `codex exec -i` (heavy per call); agy — Gemini Flash via agy (cheap,
#   agentic); claude — Claude Code stream-json; gemini — direct gemini CLI.
# CAPTION_BACKEND=agy
# CAPTION_MODEL="Gemini 3.5 Flash (Low)"   # must match the chosen backend
# CAPTION_LIMIT=0                          # cap vision calls per run (0 = all)
# CAPTION_JOBS=4                           # parallel caption calls (biggest speedup
#                                          # for image-heavy sources; raise if the
#                                          # backend tolerates it)
# GEMINI_BIN=agy                           # gemini backend only: renamed binary

# Target language for backend on-demand translations.
PW_TRANSLATE_LANG="Simplified Chinese"
# Bump these after changing the prompt contract to force new cache rows.
# PW_TRANSLATE_PROMPT_VERSION=translate:v1
# PW_ASSIST_PROMPT_VERSION=assist:v1

# Command run to launch ingest (target path/url is appended). Defaults to the
# bundled ./pipeline/ingest.py.
# INGEST_CMD="python3 /abs/path/to/pipeline/ingest.py"

# Rebuild the site after a successful ingest (leave blank to skip).
REBUILD_CMD="npm --prefix .. run build"

# CORS origins (comma-separated). Add Tailnet/custom origins explicitly.
# PW_CORS=http://localhost:4321,http://127.0.0.1:4321

# Set to 1 to exercise the ingest flow WITHOUT running the real pipeline / spending budget.
PW_INGEST_STUB=0
# Reject file uploads above this size before starting ingest.
# PW_MAX_UPLOAD_MB=250
