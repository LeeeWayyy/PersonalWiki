#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///
"""Deterministic stub for the `transcript-remote` CLI, used by
scripts/tests/test_media_e2e.sh — writes a canned transcript JSON (no network,
no GPU) so the media front door can be exercised end-to-end.

Honors `-o <path>`; mimics `transcript-remote <url> -f json -o <path>`.
Set $STUB_TRANSCRIPT_FAIL=1 to simulate a remote/job failure (exit 1, write
nothing) — for the atomicity test.
"""
import json
import os
import sys

if os.environ.get("STUB_TRANSCRIPT_FAIL"):
    print("Error: transcription failed: stubbed failure", file=sys.stderr)
    sys.exit(1)

import re

args = sys.argv[1:]
out = None
for i, a in enumerate(args):
    if a in ("-o", "--output") and i + 1 < len(args):
        out = args[i + 1]
src = next((a for a in args if a.startswith("http")), "<submitted>")
vid_m = re.search(r"[?&]v=([A-Za-z0-9_-]{11})", src)
variant = os.environ.get("STUB_TEXT_VARIANT", "").strip()
variant_suffix = f" {variant}" if variant else ""

doc = {
    "segments": [
        {"start": 0.0, "end": 4.0, "speaker": "SPEAKER_00",
         "text": "This stub transcript discusses mitochondria and ATP in cells.", "words": []},
        {"start": 4.0, "end": 9.0, "speaker": "SPEAKER_01",
         "text": "The e2e entity is the subject of this end-to-end media ingest test."
                 + variant_suffix, "words": []},
        {"start": 9.0, "end": 14.0, "speaker": "SPEAKER_00",
         "text": "Energy and biology are recurring themes throughout the discussion.", "words": []},
    ],
    "language": "en",
    # enhanced meta (mirrors the §7.1 service enhancement): ASR success flags +
    # versions + duration + resolved video_id, so the consumption path is tested.
    "meta": {"source": src, "model": "large-v3", "device": "cuda",
             "compute_type": "float16", "diarized": True,
             "align_requested": True, "align_succeeded": True,
             "diarize_requested": True, "diarize_succeeded": True,
             "duration_s": 14.0, "whisperx_version": "3.1.1",
             "pyannote_version": "3.1", "downloader": "yt-dlp",
             "yt_dlp_version": "2026.03.17", "ffmpeg_version": "6.1.1",
             "resolved_url": src, "selected_format": "251",
             "channel": "Stub Channel", "uploader": "stubber",
             "upload_date": "20260301", "job_id": "stubjob123",
             "server_version": "0.1.0",
             **({"video_id": vid_m.group(1)} if vid_m else {})},
}
blob = json.dumps(doc, ensure_ascii=False)
if out:
    with open(out, "w", encoding="utf-8") as f:
        f.write(blob)
else:
    sys.stdout.write(blob)
