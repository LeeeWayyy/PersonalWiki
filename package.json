{
  "name": "personal-wiki",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Private personal-learning website over the DailyNotes LLM-wiki vault.",
  "scripts": {
    "start": "python3 scripts/app_start.py",
    "sync": "python3 scripts/sync_content.py",
    "dev": "npm run sync && astro dev",
    "build": "npm run sync && astro build && pagefind --site dist",
    "check": "astro check && tsc --noEmit",
    "check:external": "python3 scripts/check_runtime_external.py",
    "test:unit": "PW_SYNC_WORKTREE=1 PW_CONTENT_DIR=ci-fixtures/content npm run sync && node --test tests/frontend/*.test.mjs",
    "doctor": "python3 scripts/doctor.py",
    "study:backup": "python3 scripts/study_db.py backup",
    "study:restore": "python3 scripts/study_db.py restore",
    "audit": "npm audit --audit-level=moderate",
    "preview": "astro preview",
    "serve": "node scripts/serve.mjs",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "astro": "^7.0.6",
    "mermaid": "^11.16.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.1.0",
    "mdast-util-to-string": "^4.0.0",
    "pagefind": "^1.3.0",
    "typescript": "^6.0.3",
    "unist-util-visit": "^5.0.0"
  }
}
